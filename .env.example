TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

YOUTUBE_CHANNEL_URL=https://www.youtube.com/@ChannelNameHere

DB_PATH=david_bot.db
TRANSCRIPTS_DIR=transcripts

# Hour (UTC) to run the daily check (0-23)
DAILY_CHECK_HOUR=9

# Whisper fallback settings (cpu or cuda)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8
WHISPER_MODEL=base

# VPS deploy target for fetch_transcript.py's scp hint (optional, e.g. user@host)
VPS_HOST=
VPS_BOT_DIR=/root/david_post_bot

# X / Twitter auto-posting (optional)
# Get keys at: https://developer.twitter.com/en/portal/dashboard
AUTO_POST=false
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
